generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id               String   @id @default(uuid())
  username         String   @unique
  passwordHash     String
  secretTrigger    String
  terminalPassword String   @default("admin")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Profile {
  id              String   @id @default("default")
  name            String   @default("")
  greeting        String   @default("")
  nameFontSize    Int      @default(5)
  taglineFontSize Int      @default(3)
  tagline         String
  bio             String
  email           String
  githubUrl       String
  linkedinUrl     String
  resumeUrl       String
  avatarUrl       String
  phone           String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id           String   @id @default(uuid())
  title        String
  description  String
  url          String?
  github       String?
  image        String?
  technologies String[]
  tags         String[]
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Certificate {
  id          String   @id @default(uuid())
  title       String
  issuer      String
  date        DateTime?
  url         String?
  image       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skill {
  id          String   @id @default(uuid())
  name        String
  category    String?
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Extracurricular {
  id          String   @id @default(uuid())
  text        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Interest {
  id          String   @id @default(uuid())
  name        String
  logoUrl     String?
  domain      String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EducationBead {
  id          String   @id @default(uuid())
  heading     String
  content     String
  color       String
  order       Int      @default(0)
  parentId    String?
  parent      EducationBead?  @relation("BeadToBead", fields: [parentId], references: [id], onDelete: Cascade)
  children    EducationBead[] @relation("BeadToBead")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

